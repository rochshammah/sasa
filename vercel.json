{
  "version": 2,
  "name": "jobtradesasa-frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      /* ⭐️ CRITICAL FIX: Add this rule to forward all /api requests to Render */
      "source": "/api/(.*)",
      "destination": "postgresql://jobtradesasa_user:OOkw3rIKBUsxPg8Upy4LUCCCRXpnEhpa@dpg-d3sbneeuk2gs73c3t8ng-a/jobtradesasa" 
      /* E.g., "https://jobtradesasa-api.onrender.com/api/$1" */
    },
    /* Keep all your original rewrites after the API rule */
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/service-worker.js",
      "destination": "/service-worker.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ]
}
